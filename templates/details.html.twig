{{ include('navbar.html.twig') }}


<body>
  <!--[if lte IE 9]>
    	<p class="browserupgrade">You are using an <strong>outdated</strong> browser. Please <a href="https://browsehappy.com/">upgrade your browser</a> to improve your experience and security.</p>
  <![endif]-->
  <!--********************************
   		Code Start From Here 
	******************************** -->
  <!--==============================
	Preloader
	==============================-->

  <!--==============================
    Breadcrumb
============================== -->
  <div class="breadcumb-wrapper" data-bg-src="/assets/img/hero/detail.avif">
    <div class="container z-index-common">
      <div class="breadcumb-content">
<h1 class="breadcumb-title">
    Détails du Produit
    <span class="d-block mt-2 fs-4 text-muted">{{ product.titre }}</span>
</h1>      </div>
    </div>
  </div>
  <!-- Shop Details Area Start-->
<div class="vs-product-wrapper space-top space-extra-bottom">
    <div class="container">
        <div class="row gx-60">

            {# IMAGE PRODUIT #}
            <div class="col-lg-6">
                <div class="product-slide-row wow animate__fadeInUp">

                    <div class="product-big-img">
                        <div class="img">
                        {#  #}
                            <img src="{{ asset('uploads/products/' ~ product.image) }}"
                                 alt="{{ product.titre }}">
                        </div>
                    </div>

                </div>
            </div>

            {# INFOS PRODUIT #}
            <div class="col-lg-6">
                <div class="product-about wow animate__fadeInUp">

                    <h2 class="product-title">{{ product.titre }}</h2>

                    <span class="product-author">
                        <strong>Catégorie :</strong>
                        <a href="#">
                            {{ product.category.nom ?? 'Non définie' }}
                        </a>
                    </span>

                    <p class="product-price">
                        {{ product.prix }} FCFA

                        {% if product.oldPrice is defined and product.oldPrice %}
                            <del>{{ product.oldPrice }} FCFA</del>
                        {% endif %}
                    </p>

                    <p class="text">
                        {{ product.description }}
                    </p>

                    <span class="product-instock">
                        <p>Disponibilité :</p>

                        <span>
                            {% if product.stock > 0 %}
                                <i class="fas fa-check-square"></i> En stock
                            {% else %}
                                <i class="fas fa-times"></i> Rupture
                            {% endif %}
                        </span>
                    </span>

                    {# ACTIONS #}
                    <div class="actions">

                        <input type="hidden" id="selectedLotData">
                        <!-- COMMANDER -->
                        <a href="#" class="vs-btn js-commande" id="shop" 
                            data-id="{{ product.id }}"
                            data-title="{{ product.titre }}"
                            data-price="{{ product.prix }}"
                            data-image="{{ product.image }}">
                            <i class="fa-solid fa-basket-shopping"></i> Commander 
                        </a>

                        <!-- ADD TO CART -->
                        <a href="#" class="icon-btn js-cart"
                        id="addToCartBtn"
                        data-id="{{ product.id }}"
                        data-title="{{ product.titre }}"
                        data-price="{{ product.prix }}"
                        data-image="{{ product.image }}"
                        data-lots='{{ product.lots|map(lot => {
                        "id": lot.id,
                        "nom": lot.nom,
                        "quantite": lot.quantite,
                        "prix": lot.prix
                        })|json_encode|e("html_attr") }}'>
                            <i class="fa-solid fa-basket-shopping"></i>
                        </a>

                        <!-- WISHLIST -->
                        <a href="#" class="icon-btn js-wishlist"
                        id="addToWishlistBtn"
                        data-id="{{ product.id }}"
                        data-title="{{ product.titre }}"
                        data-price="{{ product.prix }}"
                        data-image="{{ product.image }}">
                            <i class="far fa-heart"></i>
                        </a>

                    </div>

                    {# INFOS PRODUIT #}
                    <div class="product_meta">

                        <span>
                            <p>SKU :</p>
                            <span>Ds-scturbm {{ product.id }}.sn</span>
                        </span>

                        <span>
                            <p>Catégorie :</p>
                            <span>{{ product.category.nom ?? 'N/A' }}</span>
                        </span>
                        {# Lots disponibles #}
                            {% if product.lots is defined and product.lots|length > 0 %}
                                <div class="mt-4">
                                    <h5 class="mb-3 fw-bold">Lots disponibles</h5>

                                    <div class="row g-3">
                                        {% for lot in product.lots %}
                                            <div class="col-md-6">
                                                <div class="lot-select-card border rounded p-3"
                                                    style="cursor:pointer"
                                                    data-lot-id="{{ lot.id }}"
                                                    data-lot-name="{{ lot.nom }}"
                                                    data-lot-price="{{ lot.prix }}"
                                                    data-lot-qty="{{ lot.quantite }}">

                                                    <div class="fw-bold">{{ lot.nom }}</div>
                                                    <div class="small text-muted">
                                                        {{ lot.quantite }} unités
                                                    </div>
                                                    <div class="fw-bold text-primary">
                                                        {{ lot.prix|number_format(0, ',', ' ') }} FCFA
                                                    </div>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    </div>
                                </div>
                            {% endif %}

                    </div>

                </div>
            </div>

        </div>

        {# DESCRIPTION #}
        <div class="product-description wow animate__fadeInUp mt-5">

            <h3>Description</h3>

            <p  class="text" style="color:#000;">{{ product.description }}</p>

        </div>

        {# PRODUITS SIMILAIRES #}
        {% if similarProducts is not empty %}

    <div class="mt-5 mb-5 pb-5">

        <h3 class="mb-4">Produits similaires</h3>

        <div class="row vs-carousel g-4 book-carousel"
            data-slide-show="5"
            data-md-slide-show="3"
            data-sm-slide-show="2"
            data-autoplay="true">

            {% for item in similarProducts %}


                  {% include 'components/product_card.html.twig' with { product: item  } %}



            {% endfor %}

        </div>

    </div>

{% endif %}

    </div>
</div>

  <!-- Cta Area End -->
  <!--==============================
	  Footer Area
	============================== -->
{{ include('footer.html.twig') }}

<script src="{{ asset('assets/js/vendor/jquery-3.7.1.min.js') }}"></script>

<!-- Bootstrap -->
<script src="{{ asset('assets/js/bootstrap.min.js') }}"></script>

<!-- Slick Slider -->
<script src="{{ asset('assets/js/slick.min.js') }}"></script>

<!-- Magnific Popup -->
<script src="{{ asset('assets/js/jquery.magnific-popup.min.js') }}"></script>

<!-- imagesloaded -->
<script src="{{ asset('assets/js/imagesloaded.pkgd.min.js') }}"></script>

<!-- Isotope Filter -->
<script src="{{ asset('assets/js/isotope.pkgd.min.js') }}"></script>

<!-- Gsap -->
<script src="{{ asset('assets/js/gsap.min.js') }}"></script>

<!-- ScrollTrigger -->
<script src="{{ asset('assets/js/ScrollTrigger.min.js') }}"></script>

<!-- Gsap ScrollTo Plugin -->
<script src="{{ asset('assets/js/gsap-scroll-to-plugin.js') }}"></script>

<!-- Split Text -->
<script src="{{ asset('assets/js/SplitText.js') }}"></script>

<!-- Lenis -->
<script src="{{ asset('assets/js/lenis.min.js') }}"></script>

<!-- Wow JS -->
<script src="{{ asset('assets/js/wow.min.js') }}"></script>

<!-- Nice Select -->
<script src="{{ asset('assets/js/jquery.nice-select.min.js') }}"></script>

<!-- Nouislider -->
<script src="{{ asset('assets/js/nouislider.min.js') }}"></script>

<!-- Main JS -->
<script src="{{ asset('assets/js/main.js') }}"></script>
<script src="{{ asset('/assets/js/index.js') }}"></script>



</body>

</html>