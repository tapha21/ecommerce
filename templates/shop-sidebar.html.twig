<body class="shop-page">


  <!--==============================
    Breadcrumb
============================== -->
<div class="breadcumb-wrapper position-relative" data-bg-src="assets/img/hero/bookstrore.avif" 
     style="padding: 120px 0; background-size: cover; background-position: center;">
  
  <div class="position-absolute top-0 start-0 w-100 h-100" style="background: rgba(0, 0, 0, 0.4);"></div>

  <div class="container position-relative z-3">
    <div class="breadcumb-content text-center">

      <h1 class="breadcumb-title text-white fw-bold mb-3 shadow-sm" style="font-size: 3.5rem; text-shadow: 2px 2px 10px rgba(0,0,0,0.5);">
        {{ shopTitle|default('Catalogue') }}
      </h1>


    </div>
  </div>
</div>

<section class="books-layout1 shop-catalog-section space-top space-extra-bottom">
    <div class="container">
        <div class="row g-4">
            
           <div class="col-xl-3 col-lg-4 order-2 order-lg-1">
    <aside class="sidebar-area shop-sidebar">

        {# 🔎 RECHERCHE + FILTRE INTELLIGENT #}
        <div class="widget widget_search shop-search-widget wow animate__fadeInUp" data-wow-delay="0.2s">
            <h3 class="widget_title title-shep text-sm">Trouver un article</h3>

            <form method="get" action="{{ path('app_shop') }}" class="search-form-container position-relative">
                    <div class="search-form position-relative">

                        <input type="text"
                            id="smartProductSearch"
                            name="q"
                            value="{{ currentSearch }}"
                            class="form-control border-0 bg-light p-3 shadow-none"
                            placeholder="Rechercher ici..."
                            autocomplete="off"
                            style="border-radius: 8px;">

                        {# garder catégorie sélectionnée #}
                        <input type="hidden" name="cat" value="{{ currentCategory }}">
                        <input type="hidden" name="section" value="{{ currentSection }}">
                        <input type="hidden" name="category_name" value="{{ currentCategoryName }}">

                        <button type="submit"
                                class="position-absolute end-0 top-50 translate-middle-y border-0 bg-transparent me-3">
                            <i class="far fa-search" style ="color: var(--theme-color)"></i>
                        </button>

                    </div>
            </form>
        </div>

        {# 📂 CATEGORIES DYNAMIQUES #}
        <div class="widget widget_categories wow animate__fadeInUp" data-wow-delay="0.4s">
            <h3 class="widget_title title-shep text-sm">Filtres</h3>

            <ul>

                {# TOUS LES PRODUITS #}
                <li>
                  <a href="{{ path('app_shop', { q: currentSearch }) }}"
                    class="{{ currentCategory is empty and currentSection is empty and currentCategoryName is empty ? 'fw-bold' : '' }}"
                    style="{{ currentCategory is empty and currentSection is empty and currentCategoryName is empty ? 'color: var(--theme-color);' : '' }}">
                        Tous les produits
                  </a>
                </li>

                <li>
                    <a href="{{ path('app_shop', { section: 'phares', q: currentSearch }) }}"
                       class="{{ currentSection == 'phares' ? 'fw-bold' : '' }}"
                       style="{{ currentSection == 'phares' ? 'color: var(--theme-color);' : '' }}">
                        Produits phares
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_shop', { section: 'promotions', q: currentSearch }) }}"
                       class="{{ currentSection == 'promotions' ? 'fw-bold' : '' }}"
                       style="{{ currentSection == 'promotions' ? 'color: var(--theme-color);' : '' }}">
                        Promotions
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_shop', { section: 'nouveautes', q: currentSearch }) }}"
                       class="{{ currentSection == 'nouveautes' ? 'fw-bold' : '' }}"
                       style="{{ currentSection == 'nouveautes' ? 'color: var(--theme-color);' : '' }}">
                        Nouveautés
                    </a>
                </li>

                <li>
                    <a href="{{ path('app_shop', { section: 'best_sellers', q: currentSearch }) }}"
                       class="{{ currentSection == 'best_sellers' ? 'fw-bold' : '' }}"
                       style="{{ currentSection == 'best_sellers' ? 'color: var(--theme-color);' : '' }}">
                        Best sellers
                    </a>
                </li>

            </ul>
        </div>

        {# 📂 CATEGORIES DYNAMIQUES #}
        <div class="widget widget_categories wow animate__fadeInUp" data-wow-delay="0.4s">
            <h3 class="widget_title title-shep text-sm">Rayons</h3>

            <ul>

                {# LISTE DES CATEGORIES #}
                {% for cat in categories %}
                    <li>
                        <a href="{{ path('app_shop', {
                            cat: cat.id,
                            q: currentSearch
                        }) }}"
                           class="{{ currentCategory == cat.id ? 'fw-bold' : '' }}"
                           style="{{ currentCategory == cat.id ? 'color: var(--theme-color);' : '' }}"
                           >
                            {{ cat.nom }}
                        </a>
                    </li>
                {% endfor %}

            </ul>
        </div>

        </aside>
    </div>

           <div class="col-xl-9 col-lg-8 order-1 order-lg-2">

    <div class="shop-results-bar mb-4">
        <span id="shopResultCount">{{ products|length }}</span>
        produit{{ products|length > 1 ? 's' : '' }} trouvé{{ products|length > 1 ? 's' : '' }}
    </div>

    <div class="row g-4" id="product-list">

        {% for product in products %}

        {% include 'components/product_card.html.twig' with { 'product': product } %}


        {% endfor %}

    </div>

    <div id="emptyShopResults" class="shop-empty-results text-center py-5 d-none">
        <i class="fa-solid fa-magnifying-glass mb-3"></i>
        <h5 class="fw-bold">Aucun produit trouvé</h5>
        <p class="text-muted mb-0">Essayez un autre mot-clé ou changez de filtre.</p>
    </div>

    <!-- PAGINATION -->
    <div class="vs-pagination pt-4 d-flex justify-content-center">
        <ul class="pagination-list d-flex list-unstyled gap-2" id="pagination"></ul>
    </div>

    </div>
            </div>
        </div>
</section>

