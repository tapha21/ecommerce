  <!-- Main Js File -->
  <script src="assets/js/main.js"></script>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
        const items = document.querySelectorAll(".product-item");
        const pagination = document.getElementById("pagination");
        const perPage = 12;
        let currentPage = 1;

        function showPage(page) {
            const totalPages = Math.ceil(items.length / perPage);
            if (page < 1 || page > totalPages) return;
            
            currentPage = page;
            items.forEach((item, index) => {
                item.style.display = (index >= (page - 1) * perPage && index < page * perPage) ? "block" : "none";
            });
            updatePagination();
        }

        function createPageLink(text, page, isActive = false, isDisabled = false) {
            let li = document.createElement("li");
            let a = document.createElement("a");
            a.href = "#";
            a.innerText = text;
            
            if (isDisabled) {
                a.style.pointerEvents = "none";
                a.style.opacity = "0.5";
            }
            if (isActive) a.classList.add("active");

            a.addEventListener("click", (e) => {
                e.preventDefault();
                if (!isDisabled) showPage(page);
            });

            li.appendChild(a);
            return li;
        }

        function updatePagination() {
            pagination.innerHTML = "";
            const totalPages = Math.ceil(items.length / perPage);

            // Bouton Précédent
            pagination.appendChild(createPageLink("«", currentPage - 1, false, currentPage === 1));

            // Pages numérotées
            for (let i = 1; i <= totalPages; i++) {
                pagination.appendChild(createPageLink(i, i, i === currentPage));
            }

            // Bouton Suivant
            pagination.appendChild(createPageLink("»", currentPage + 1, false, currentPage === totalPages));
        }

        showPage(1);
    });
</script>
<script>
    document.addEventListener("DOMContentLoaded", () => {
        const items = Array.from(document.querySelectorAll(".product-item"));
        const pagination = document.getElementById("pagination");
        const searchInput = document.getElementById("smartProductSearch");
        const resultCount = document.getElementById("shopResultCount");
        const emptyResults = document.getElementById("emptyShopResults");
        const perPage = 12;
        let currentPage = 1;
        let filteredItems = items;

        function normalize(value) {
            return (value || "")
                .toLowerCase()
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .trim();
        }

        function showPage(page) {
            const totalPages = Math.max(1, Math.ceil(filteredItems.length / perPage));
            if (page < 1 || page > totalPages) return;

            currentPage = page;
            items.forEach(item => item.style.display = "none");
            filteredItems.forEach((item, index) => {
                item.style.display = (index >= (page - 1) * perPage && index < page * perPage) ? "" : "none";
            });

            if (resultCount) resultCount.textContent = filteredItems.length;
            if (emptyResults) emptyResults.classList.toggle("d-none", filteredItems.length > 0);
            renderPagination();
        }

        function createPageLink(text, page, isActive = false, isDisabled = false) {
            const li = document.createElement("li");
            const a = document.createElement("a");
            a.href = "#";
            a.innerText = text;

            if (isActive) a.classList.add("active");
            if (isDisabled) {
                a.style.pointerEvents = "none";
                a.style.opacity = "0.5";
            }

            a.addEventListener("click", (e) => {
                e.preventDefault();
                if (!isDisabled) showPage(page);
            });

            li.appendChild(a);
            return li;
        }

        function renderPagination() {
            if (!pagination) return;

            pagination.innerHTML = "";
            const totalPages = Math.ceil(filteredItems.length / perPage);
            if (totalPages <= 1) return;

            pagination.appendChild(createPageLink("«", currentPage - 1, false, currentPage === 1));

            for (let i = 1; i <= totalPages; i++) {
                pagination.appendChild(createPageLink(i, i, i === currentPage));
            }

            pagination.appendChild(createPageLink("»", currentPage + 1, false, currentPage === totalPages));
        }

        function applySearch() {
            const term = normalize(searchInput?.value);

            filteredItems = term
                ? items.filter(item => normalize(item.dataset.search || item.textContent).includes(term))
                : items;

            showPage(1);
        }

        searchInput?.addEventListener("input", applySearch);
        applySearch();
    });
</script>
</body>

</html>
