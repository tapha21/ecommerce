{% extends 'base.html.twig' %}

{% block title %}Dashboard | DeenAdmin{% endblock %}

{% block body %}
<div class="container-fluid">
    
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h2 class="fw-bold m-0" style="color: var(--admin-dark);">Tableau de bord</h2>
            <p class="text-muted small">Gestion des activités et des commandes</p>
        </div>
        <div class="text-end">
            <span class="badge bg-white text-dark shadow-sm py-2 px-3 rounded-pill border">
                <i class="fa-regular fa-calendar-days me-2 text-primary"></i>{{ "now"|date("d/m/Y") }}
            </span>
        </div>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Utilisateurs</h6>
                        <h2 class="fw-bold m-0">{{ total_users }}</h2>
                    </div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background: rgba(255,255,255,0.2);">
                        <i class="fa-solid fa-users fa-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-success text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Commandes</h6>
                        <h2 class="fw-bold m-0">{{ total_orders }}</h2>
                    </div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background: rgba(255,255,255,0.2);">
                        <i class="fa-solid fa-cart-shopping fa-xl"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm rounded-4 p-3 text-white" style="background-color: #2c3e50">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase small fw-bold opacity-75">Ventes Totales</h6>
                        <h2 class="fw-bold m-0">{{ total_sales|number_format(0, ',', ' ') }} <small style="font-size: 0.6em;">FCFA</small></h2>
                    </div>
                    <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; background: rgba(255,255,255,0.2);">
                        <i class="fa-solid fa-wallet fa-xl"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 mb-4">
        <div class="card-body p-3">

            <div class="row g-3 align-items-end">

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Rechercher</label>

                    <input
                        type="text"
                        id="searchInput"
                        class="form-control form-control-sm border-light bg-light rounded-pill"
                        placeholder="ID, Client, téléphone..."
                    >
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Statut</label>

                    <select
                        id="statusFilter"
                        class="form-select form-select-sm border-light bg-light rounded-pill"
                    >
                        <option value="">Tous les statuts</option>
                        <option value="en_attente">En attente</option>
                        <option value="payer">Payée</option>
                        <option value="expedier">expedier</option>
                        <option value="annuler">Annulée</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">
                        Paiement
                    </label>

                    <select
                        id="paymentFilter"
                        class="form-select form-select-sm border-light bg-light rounded-pill"
                    >
                        <option value="">Tous</option>
                        <option value="cash_on_delivery">À la livraison</option>
                        <option value="wave">Wave</option>
                        <option value="orange_money">Orange Money</option>
                        <option value="card">Carte bancaire</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Date</label>

                    <input
                        type="date"
                        id="dateFilter"
                        class="form-control form-control-sm border-light bg-light rounded-pill"
                    >
                </div>

                <div class="col-md-3">
                    <button
                        type="button"
                        id="resetFilters"
                        class="btn btn-sm btn-dark w-100 rounded-pill py-2 fw-bold"
                        >
                            Réinitialiser
                        </button>
                </div>

            </div>

        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header bg-white p-4 border-0 d-flex justify-content-between align-items-center">
            <h4 class="fw-bold m-0" style="color: var(--admin-dark);">Gestion des commandes</h4>
        </div>
        
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="adminOrderTable">
                    <thead class="bg-light text-uppercase" style="font-size: 11px;">
                        <tr class="text-muted">
                            <th class="ps-4 py-3">ID</th>
                            <th class="py-3">Client</th>
                            <th class="py-3">Adresse</th>
                            <th class="py-3">Mode Paiement</th>
                            <th class="py-3">Date / Montant</th>
                            <th class="py-3">Statut</th>
                            <th class="py-3 text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in orders %}
                            <tr class="order-row"
                             data-status="{{ order.status.value }}" 
                             data-payment="{{ order.paymentMethod.value }}">
                                <td class="ps-4 fw-bold">#{{ order.id }}</td>
                                <td>
                                    <div class="fw-bold text-dark">{{ order.user ? order.user.prenom ~ ' ' ~ order.user.nom : order.guestName }}</div>
                                    <div class="text-muted small"><i class="fa-solid fa-phone me-1 opacity-50"></i> {{ order.user ? order.user.telephone : order.guestPhone }}</div>
                                </td>
                                <td>
                                    <div class="small fw-bold">{{ order.user ? order.user.adresse : order.guestAddress }}</div>
                                    <div class="small text-muted">
                                        {{ order.user ? order.user.email : 'Pas de compte' }}
                                    </div>       
                                    </td>
                                    <td>
                                        <div class="fw-bold text-primary">{{ order.paymentMethod.label }}</div>
                                    </td>
                                <td>
                                   <div class="small text-muted order-date" data-date="{{ order.createdAt|date('Y-m-d') }}">
                                        {{ order.createdAt|date('d/m/Y') }}
                                    </div>
                                    <div class="fw-bold text-primary">{{ order.total|number_format(0, ',', ' ') }} FCFA</div>
                                </td>
                                <td>
                                    {% set b_class = 'bg-secondary' %}
                                    {% if order.status.value == 'en_attente' %}{% set b_class = 'bg-warning text-dark' %}
                                    {% elseif order.status.value == 'payer' %}{% set b_class = 'bg-success' %}
                                    {% elseif order.status.value == 'expedier' %}{% set b_class = 'bg-info' %}
                                    {% elseif order.status.value == 'annuler' %}{% set b_class = 'bg-danger' %}
                                    {% endif %}
                                    <span class="badge {{ b_class }} rounded-pill px-3 py-2 text-uppercase" style="font-size: 9px;">
                                        {{ order.status.value }}
                                    </span>
                                </td>
                                <td>
                                    <form method="post"
                                        action="{{ path('admin_order_status', {id: order.id}) }}"
                                        class="d-flex justify-content-center gap-1">

                                        <input type="hidden" name="_method" value="PATCH">

                                        <select name="status" class="form-select form-select-sm border-0 bg-light rounded-pill shadow-none"
                                                style="font-size: 11px; width: 110px;">

                                                <option value="en_attente" {{ order.status.value == 'en_attente' ? 'selected' : '' }}>
                                            Attente
                                        </option>

                                        <option value="payer" {{ order.status.value == 'payer' ? 'selected' : '' }}>
                                            Payée
                                        </option>

                                        <option value="Expedier" {{ order.status.value == 'expedier' ? 'selected' : '' }}>
                                            Expédiée
                                        </option>

                                        <option value="annuler" {{ order.status.value == 'annuler' ? 'selected' : '' }}>
                                            Annulée
                                        </option>

                                        </select>

                                        <button type="submit" class="btn btn-sm btn-dark rounded-circle">
                                            <i class="fa-solid fa-rotate"></i>
                                        </button>

                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card-footer bg-white border-0 py-4">
            <nav>
                <ul class="pagination justify-content-center mb-0" id="orderPagination"></ul>
            </nav>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const rowsPerPage = 10;
    const table = document.getElementById('adminOrderTable');
    const tbody = table.querySelector('tbody');
    const rows = Array.from(tbody.querySelectorAll('.order-row'));
    const pagination = document.getElementById('orderPagination');
    
    function displayPage(page) {
        const start = (page - 1) * rowsPerPage;
        const end = start + rowsPerPage;
        
        rows.forEach((row, i) => {
            row.style.display = (i >= start && i < end) ? '' : 'none';
        });
        
        renderPagination(page);
    }

    function renderPagination(activePage) {
        const pageCount = Math.ceil(rows.length / rowsPerPage);
        pagination.innerHTML = '';
        
        if (pageCount <= 1) return;

        for (let i = 1; i <= pageCount; i++) {
            const li = document.createElement('li');
            li.className = `page-item ${i === activePage ? 'active' : ''}`;
            li.innerHTML = `<a class="page-link border-0 mx-1 rounded-3 shadow-sm ${i === activePage ? 'bg-primary text-white' : 'bg-light text-dark'}" href="#">${i}</a>`;
            li.addEventListener('click', (e) => {
                e.preventDefault();
                displayPage(i);
            });
            pagination.appendChild(li);
        }
    }

    displayPage(1);
});
document.addEventListener('DOMContentLoaded', () => {

    const searchInput = document.getElementById('searchInput');
    const statusFilter = document.getElementById('statusFilter');
    const dateFilter = document.getElementById('dateFilter');
    const resetBtn = document.getElementById('resetFilters');
    const paymentFilter = document.getElementById('paymentFilter');
    const rows = document.querySelectorAll('.order-row');

    function normalize(text) {
        return text
            .toLowerCase()
            .normalize("NFD")
            .replace(/[\u0300-\u036f]/g, "");
    }

    function filterOrders() {

        const search = normalize(searchInput.value);
        const status = statusFilter.value;
        const date = dateFilter.value;
        const payment = paymentFilter.value;

        rows.forEach(row => {

            const rowText = normalize(row.innerText);

            const rowStatus = row.dataset.status;

            const dateElement = row.querySelector('.order-date');

            const rowDate = dateElement
                ? dateElement.dataset.date
                : '';

            let visible = true;

            // 🔎 Recherche intelligente
            if (search && !rowText.includes(search)) {
                visible = false;
            }

            // 📦 Filtre statut
            if (status && rowStatus !== status) {
                visible = false;
            }

            // 📅 Filtre date
            if (date && rowDate !== date) {
                visible = false;
            }
            if (payment && row.dataset.payment !== payment) {
                visible = false;
            }

            row.style.display = visible ? '' : 'none';

        });

    }

    searchInput.addEventListener('input', filterOrders);
    statusFilter.addEventListener('change', filterOrders);
    dateFilter.addEventListener('change', filterOrders);
    paymentFilter.addEventListener('change', filterOrders);

    resetBtn.addEventListener('click', () => {

        searchInput.value = '';
        statusFilter.value = '';
        dateFilter.value = '';

        filterOrders();

    });

});
</script>

<style>
    .card { transition: all 0.2s ease; }
    .page-link:hover { background-color: var(--theme-color) !important; color: white !important; }
    .form-control:focus, .form-select:focus { border-color: var(--theme-color); box-shadow: none; }
</style>
{% endblock %}
