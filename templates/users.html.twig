{% extends 'base.html.twig' %}

{% block title %}Utilisateurs | Admin{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="fw-bold">Gestion des utilisateurs</h2>

        <a class="btn btn-dark"
            data-bs-toggle="modal"
            data-bs-target="#createUserModal">
                + Ajouter un utilisateur
        </a>
    </div>

    <!-- FILTRES -->
    <div class="card mb-3 p-3 shadow-sm border-0">
        <div class="row g-2">

            <!-- SEARCH -->
            <div class="col-md-6">
                <input type="text"
                       id="searchUser"
                       class="form-control"
                       placeholder="Rechercher nom, email, téléphone...">
            </div>

            <!-- ROLE -->
            <div class="col-md-3">
                <select id="filterRole" class="form-select">

                    <option value="">Tous les rôles</option>

                    {% set rolesList = [] %}

                    {% for u in users %}
                        {% for role in u.roles %}

                            {% if role not in rolesList %}

                                {% set rolesList = rolesList|merge([role]) %}

                                <option value="{{ role|lower }}">
                                    {{ role }}
                                </option>

                            {% endif %}

                        {% endfor %}
                    {% endfor %}

                </select>
            </div>

        </div>
    </div>

    <!-- TABLE -->
    <div class="card shadow-sm border-0">

        <div class="table-responsive">

            <table class="table align-middle" id="userTable">

                <thead class="table-light">
                    <tr>
                        <th>Utilisateur</th>
                        <th>Téléphone</th>
                        <th>Email</th>
                        <th>Adresse</th>
                        <th>Rôle</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>

                {% for u in users %}

                    <tr class="user-row"

                        data-name="{{ (u.nom ~ ' ' ~ u.prenom)|lower }}"
                        data-phone="{{ u.telephone|default('')|lower }}"
                        data-email="{{ u.email|default('')|lower }}"
                        data-address="{{ u.adresse|default('')|lower }}"
                        data-role="{{ u.roles|join(' ')|lower }}"
                    >

                        <!-- USER -->
                        <td>
                            <div class="fw-bold">
                                {{ u.nom }} {{ u.prenom }}
                            </div>

                            <small class="text-muted">
                                ID : #{{ u.id }}
                            </small>
                        </td>

                        <!-- PHONE -->
                        <td>
                            {{ u.telephone }}
                        </td>

                        <!-- EMAIL -->
                        <td>
                            {{ u.email }}
                        </td>

                        <!-- ADDRESS -->
                        <td>
                            {{ u.adresse }}
                        </td>

                        <!-- ROLE -->
                        <td>

                            {% for role in u.roles %}

                                {% if role == 'ROLE_ADMIN' %}

                                    <span class="badge bg-dark">
                                        Admin
                                    </span>

                                {% elseif role == 'ROLE_USER' %}

                                    <span class="badge bg-primary">
                                        User
                                    </span>

                                {% else %}

                                    <span class="badge bg-secondary">
                                        {{ role }}
                                    </span>

                                {% endif %}

                            {% endfor %}

                        </td>

                        <!-- ACTIONS -->
                        <td class="text-center">

                             <button class="btn btn-sm btn-primary"
                           onclick='openEditModal({
                            id: {{ u.id }},
                            nom: {{ u.nom|json_encode|raw }},
                            prenom: {{ u.prenom|json_encode|raw }},
                            email: {{ u.email|json_encode|raw }},
                            telephone: {{ u.telephone|json_encode|raw }},
                            adresse: {{ u.adresse|json_encode|raw }}
                        })'>
                        Edit
                    </button>

                            <a href="{{ path('admin_user_delete', {id: u.id}) }}"
                                class="btn btn-sm btn-danger"
                                onclick="return confirm('Supprimer cet utilisateur ?')">
                                    Delete
                                </a>

                        </td>

                    </tr>

                {% endfor %}

                </tbody>

            </table>

        </div>

        <!-- PAGINATION -->
        <div class="card-footer bg-white border-0">

            <nav>
                <ul class="pagination justify-content-center mb-0"
                    id="pagination">
                </ul>
            </nav>

        </div>

    </div>

</div>
<!-- CREATE USER MODAL -->
<div class="modal fade" id="createUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form method="post" action="{{ path('admin_user_create') }}">

                <div class="modal-header">
                    <h5 class="modal-title">Ajouter un utilisateur</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input name="user[nom]" class="form-control mb-2" placeholder="Nom" required>
                    <input name="user[prenom]" class="form-control mb-2" placeholder="Prénom" required>

                    <input name="user[email]" type="email" class="form-control mb-2" placeholder="Email" required>

                    <input name="user[telephone]" class="form-control mb-2" placeholder="Téléphone">
                    <input name="user[adresse]" class="form-control mb-2" placeholder="Adresse">

                    <input name="user[password]" type="password" class="form-control mb-2" placeholder="Mot de passe" required>

                    <select name="user[roles]" class="form-control mb-2">
                        <option value='["ROLE_USER"]'>User</option>
                        <option value='["ROLE_ADMIN"]'>Admin</option>
                    </select>

                </div>

                <div class="modal-footer">
                    <button class="btn btn-dark">Créer</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- EDIT USER MODAL -->
<div class="modal fade" id="editUserModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <form method="post" id="editUserForm">

                <div class="modal-header">
                    <h5 class="modal-title">Modifier utilisateur</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input name="nom" id="edit_nom" class="form-control mb-2">
                    <input name="prenom" id="edit_prenom" class="form-control mb-2">
                    <input name="email" id="edit_email" class="form-control mb-2">
                    <input name="telephone" id="edit_phone" class="form-control mb-2">
                    <input name="adresse" id="edit_address" class="form-control mb-2">

                </div>

                <div class="modal-footer">
                    <button class="btn btn-primary">Modifier</button>
                </div>

            </form>

        </div>
    </div>
</div>

<!-- JS -->
<script>

document.addEventListener('DOMContentLoaded', () => {

    const searchInput = document.getElementById('searchUser');
    const roleFilter = document.getElementById('filterRole');

    const rows = Array.from(document.querySelectorAll('.user-row'));

    const pagination = document.getElementById('pagination');

    let currentPage = 1;

    const perPage = 10;

    // NORMALIZE
    function normalize(str) {

        return (str || '')
            .toLowerCase()
            .normalize('NFD')
            .replace(/[\u0300-\u036f]/g, '');

    }

    // FILTER USERS
    function getFilteredRows() {

        const search = normalize(searchInput.value);

        const role = roleFilter.value;

        return rows.filter(row => {

            const name = normalize(row.dataset.name);

            const phone = normalize(row.dataset.phone);

            const email = normalize(row.dataset.email);

            const address = normalize(row.dataset.address);

            const rowRole = row.dataset.role;

            let matchSearch = true;

            let matchRole = true;

            // SEARCH
            if (search) {

                matchSearch =
                    name.includes(search) ||
                    phone.includes(search) ||
                    email.includes(search) ||
                    address.includes(search);

            }

            // ROLE
            if (role) {

                matchRole = rowRole.includes(role);

            }

            return matchSearch && matchRole;

        });

    }

    // RENDER TABLE
    function renderTable() {

        const filteredRows = getFilteredRows();

        rows.forEach(row => {
            row.style.display = 'none';
        });

        const start = (currentPage - 1) * perPage;

        const end = start + perPage;

        filteredRows
            .slice(start, end)
            .forEach(row => {
                row.style.display = '';
            });

        renderPagination(filteredRows.length);

    }

    // PAGINATION
    function renderPagination(totalItems) {

        pagination.innerHTML = '';

        const totalPages = Math.ceil(totalItems / perPage);

        // PREVIOUS
        const prev = document.createElement('li');

        prev.className =
            'page-item ' + (currentPage === 1 ? 'disabled' : '');

        prev.innerHTML =
            `<a class="page-link" href="#">«</a>`;

        prev.addEventListener('click', e => {

            e.preventDefault();

            if (currentPage > 1) {

                currentPage--;

                renderTable();

            }

        });

        pagination.appendChild(prev);

        // PAGES
        for (let i = 1; i <= totalPages; i++) {

            const li = document.createElement('li');

            li.className =
                'page-item ' +
                (i === currentPage ? 'active' : '');

            li.innerHTML =
                `<a class="page-link" href="#">${i}</a>`;

            li.addEventListener('click', e => {

                e.preventDefault();

                currentPage = i;

                renderTable();

            });

            pagination.appendChild(li);

        }

        // NEXT
        const next = document.createElement('li');

        next.className =
            'page-item ' +
            (currentPage === totalPages || totalPages === 0
                ? 'disabled'
                : '');

        next.innerHTML =
            `<a class="page-link" href="#">»</a>`;

        next.addEventListener('click', e => {

            e.preventDefault();

            if (currentPage < totalPages) {

                currentPage++;

                renderTable();

            }

        });

        pagination.appendChild(next);

    }

    // RESET PAGE
    function resetAndRender() {

        currentPage = 1;

        renderTable();

    }

    // EVENTS
    searchInput.addEventListener('input', resetAndRender);

    roleFilter.addEventListener('change', resetAndRender);

    // INIT
    renderTable();

});

</script>
<script>
function openEditModal(user) {

    document.getElementById('edit_nom').value = user.nom;
    document.getElementById('edit_prenom').value = user.prenom;
    document.getElementById('edit_email').value = user.email;
    document.getElementById('edit_phone').value = user.telephone;
    document.getElementById('edit_address').value = user.adresse;

    document.getElementById('editUserForm').action = "/auth/edit/" + user.id;

    new bootstrap.Modal(document.getElementById('editUserModal')).show();
}
</script>

{% endblock %}