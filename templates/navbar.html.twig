<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="x-ua-compatible" content="ie=edge">
  <title>Deen-Shop </title>
  <meta name="author" content="vecuro">
  <meta name="description" content="Deen-Shop">
  <meta name="keywords" content="Deen-Shop">
  <meta name="robots" content="INDEX,FOLLOW">
  <!-- Mobile Specific Metas -->
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <!-- Favicons -->
  <link rel="icon" href="/assets/img/brand/logoN.jpeg" type="image/svg+xml">
  <link rel="icon" href="/assets/img/brand/logoN.jpeg" type="image/png" sizes="32x32">
  <link rel="shortcut icon" href="/assets/img/brand/logoN.jpeg" type="image/x-icon">
  <link rel="apple-touch-icon" href="/assets/img/brand/logoN.jpeg">
  <!--==============================
	  Google Fonts
	============================== -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Josefin+Sans:ital,wght@0,100..700;1,100..700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <!--==============================
	    All CSS File
	============================== -->
  <!-- Bootstrap -->
  <link rel="stylesheet" href="/assets/css/bootstrap.min.css">
  <!-- Fontawesome Icon -->
  <link rel="stylesheet" href="/assets/css/fontawesome.min.css">
  <!-- Magnific Popup -->
  <link rel="stylesheet" href="/assets/css/magnific-popup.min.css">
  <!-- Slick Slider -->
  <link rel="stylesheet" href="/assets/css/slick.min.css">
  <!-- nice-select -->
  <link rel="stylesheet" href="/assets/css/nice-select.min.css">
  <!-- animate js -->
  <link rel="stylesheet" href="/assets/css/animate.min.css">
  <!-- nouislider js -->
  <link rel="stylesheet" href="/assets/css/nouislider.css">
  <!-- Theme Custom CSS -->
  <link rel="stylesheet" href="/assets/css/style.css">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
</head>
<body>
  <div class="preloader">
    <button class="vs-btn preloaderCls">Annuler le chargement </button>
    <div class="preloader-inner">
      <img src="/assets/img/brand/logoN.jpeg" alt="logo">
      <span class="loader"></span>
    </div>
</div>

<button class="back-to-top" id="backToTop" aria-label="Retour en haut">
    <span class="progress-circle">
      <svg viewBox="0 0 100 100">
          <circle class="bg" cx="50" cy="50" r="40"></circle>
          <circle class="progress" cx="50" cy="50" r="40"></circle>
      </svg>
      <span class="progress-percentage" id="progressPercentage">0%</span>
    </span>
</button>

<a href="https://wa.me/221778181259"
   class="deen-whatsapp-float"
   target="_blank"
   rel="noopener"
   aria-label="Envoyer un message WhatsApp">
    <i class="fa-brands fa-whatsapp"></i>
</a>

<div class="vs-menu-wrapper">
    <div class="vs-menu-area text-center">

      <!-- ✅ LOGO MOBILE (VISIBLE TOUJOURS) -->
      <div class="mobile-logo">
        <a href="{{ path('app_home') }}">
          <img src="/assets/img/brand/logoN.jpeg"
               alt="ebukz"
               class="logo img-fluid"
               style="max-height:120px; width:auto;">
        </a>
        <button class="vs-menu-toggle"><i class="fal fa-times"></i></button>
      </div>

      <div class="vs-mobile-menu">
        <ul>
          <li><a href="{{ path('app_home') }}">Accueil</a></li>
          <li><a href="{{ path('app_shop') }}">Boutique</a></li>
          <li class="menu-item-has-children">
            <a href="">Categories</a>
            <ul class="sub-menu">
               {% for category in categories %}
                                    <li>
                                        <a href="{{ path('app_shop', { 'cat': category.id }) }}"
                                        class="dropdown-item category-link"
                                        data-id="{{ category.id }}">
                                            {{ category.nom }}
                                        </a>
                                    </li>
                                {% endfor %}
            </ul>
          </li>

          <li><a href="#">Contact</a></li>
        </ul>

        <div class="deen-mobile-actions">
            <a href="#" class="deen-mobile-action-item">
                <i class="fal fa-location me-2"></i>
                <span>Scat-urbam</span>
            </a>

            <div class="deen-mobile-socials">
                <a href="https://www.tiktok.com/@sen_deen_shop" aria-label="TikTok">
                    <i class="fa-brands fa-tiktok"></i>
                </a>
                <a href="https://www.instagram.com/sen_deen_shop/" aria-label="Instagram">
                    <i class="fab fa-instagram"></i>
                </a>
            </div>

            {% if app.user %}
                <a href="{{ path('profile') }}" class="deen-mobile-action-item">
                    <i class="fa-solid fa-user me-2"></i>
                    <span>Mon profil</span>
                </a>
                <a href="{{ path('logout') }}" class="deen-mobile-action-item">
                    <i class="fa-solid fa-right-from-bracket me-2"></i>
                    <span>Déconnexion</span>
                </a>
            {% else %}
                <a href="#" class="deen-mobile-action-item" data-bs-toggle="modal" data-bs-target="#authModal">
                    <i class="fa-solid fa-user me-2"></i>
                    <span>Connexion</span>
                </a>
            {% endif %}
        </div>
      </div>

    </div>
</div>

<div class="popup-search-box d-none d-lg-block">
    <button class="searchClose"><i class="fal fa-times"></i></button>

    <form action="{{ path('app_shop') }}" method="GET">
        <input type="text"
               name="q"
               class="border-theme"
               placeholder="Que recherchez-vous ?">

        <button type="submit">
            <i class="fal fa-search"></i>
        </button>
    </form>
</div>
<header class="deen-navbar fixed-top border-bottom bg-white">

    <!-- 1. TOP BAR (Rose) -->
    <div class="deen-topbar py-2 d-md-block" style="background-color: var(--theme-color);">
        <div class="container">
            <div class="row align-items-center justify-content-between">
                <div class="col-auto ">
                    <div class="deen-topbar-info text-white small">
                        <i class="fa-solid fa-truck-fast me-2"></i>
                        <span class="me-3">Livraison la plus rapide dans votre ville</span>
                        <i class="fas fa-envelope me-2"></i>
                        <a href="mailto:DeenShop@gmail.com" class="text-white text-decoration-none">DeenShop@gmail.com</a>
                    </div>
                </div>
                <div class="col-auto">
                    <div class="deen-topbar-actions d-flex align-items-center text-white small gap-3">
                        <div class="dropdown">
                            <a class="text-white text-decoration-none ">
                                <i class="fal fa-location me-1"></i>  Scat-urbam
                            </a>
                        </div>
                        <div class="vr"></div> <!-- Ligne de séparation -->
                        <div class="d-flex gap-2">
                            <a href="https://www.tiktok.com/@sen_deen_shop" class="text-white"><i class="fa-brands fa-tiktok"></i></a>
                            <a href="https://www.instagram.com/sen_deen_shop/" class="text-white"><i class="fab fa-instagram"></i></a>
                        </div>
                           {% if app.user %}
                                <div class="dropdown">
                                    <a class="text-white dropdown-toggle" data-bs-toggle="dropdown" style="cursor: pointer;">
                                        <i class="fa-solid fa-user"></i>
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-end">
                                        <li><a class="dropdown-item" href="{{ path('profile') }}">Mon profil</a></li>
                                        <li><a class="dropdown-item" href="{{ path('logout') }}">Déconnexion</a></li>
                                    </ul>
                                </div>
                            {% else %}
                                {# On ajoute data-bs-toggle et data-bs-target #}
                                <a href="#" class="text-white" data-bs-toggle="modal" data-bs-target="#authModal">
                                    <i class="fa-solid fa-user"></i>
                                </a>
                            {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. MAIN HEADER (Middle) -->
    <div class="deen-main-header py-3 bg-white">
        <div class="container">
            <div class="row align-items-center justify-content-between flex-nowrap ">
                
                <!-- LOGO -->
                <!-- LOGO -->
<div class="col-auto">
    <a href="{{ path('app_home') }}" class="d-block">
        <img
            src="/assets/img/brand/logoN.jpeg"
            alt="Logo Deen Shop"
            class="deen-header-logo img-fluid"
            style="
                max-height: 90px;
                width: auto;
                height: auto;
            "
        >
    </a>
</div>

                <!-- SEARCH BAR (Cachée sur Mobile < 992px) -->
               <div class="col d-none d-lg-block px-4">
    <form action="{{ path('app_shop') }}" method="GET">
        <div class="input-group border rounded-pill overflow-visible">

            <button class="btn btn-light dropdown-toggle border-0 px-3" type="button" data-bs-toggle="dropdown">
                Catégories
            </button>

            <ul class="dropdown-menu">
                {% for category in categories %}
                    <li>
                        <a href="{{ path('app_shop', { 'cat': category.id }) }}"
                           class="dropdown-item category-link"
                           data-id="{{ category.id }}">
                            {{ category.nom }}
                        </a>
                    </li>
                {% endfor %}
            </ul>

            <!-- 🔥 IMPORTANT : name="q" -->
            <input type="text"
                   name="q"
                   value="{{ currentSearch ?? '' }}"
                   class="form-control border-0 shadow-none"
                   placeholder="Rechercher votre produit...">

            <button class="btn border-0 px-3" style="background-color: #b57c7c; color: white;" type="submit">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>

        </div>
    </form>
</div>

                <!-- ACTIONS & BOUTONS -->
                <div class="col-auto">
                    <div class="d-flex align-items-center gap-2 gap-md-3">
                        
                        <!-- Wishlist -->
                        <a href="{{ path('app_wishlist_index') }}"class="deen-action-btn btn rounded-circle position-relative d-flex align-items-center justify-content-center p-0"
                            style="width: 45px; height: 45px; color: var(--theme-color);">

                                <i class="fal fa-heart"></i>

                                <span class="wishlist-count position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark">
                                    0
                                </span>

                            </a>

                        <!-- Cart -->
                        <a href="{{ path('app_cart_index') }}" class="deen-action-btn btn rounded-circle position-relative d-flex align-items-center justify-content-center p-0" style="width: 45px; height: 45px; background-color: var(--theme-color); color:#ffff">
                        <i class="fa-solid fa-basket-shopping"></i>
                        <span class="cart-count position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark">
                            0
                        </span>                        </a>

                        <!-- Phone Info (Caché sur Mobile < 768px) -->
                        <div class="d-none d-md-flex align-items-center gap-2 ps-2 border-start">
                            <div class="rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px; background-color: var(--theme-color); color:#ffff">
                                <i class="fas fa-phone"></i>
                            </div>
                            <div class="lh-1">
                                <small class="text-muted d-block" style="font-size: 10px;">Appelez-Nous 24h/24</small>
                                <strong class="small fw-bold">(+221) 77 818 12 59</strong>
                            </div>
                        </div>

                        <!-- HAMBURGER MENU (Visible seulement sur Mobile/Tablette) -->
                        <button class="btn border-0 d-lg-none p-0 ms-2 vs-menu-toggle">
                            <i class="fal fa-bars text-dark"></i>
                        </button>

                    </div>
                </div>

            </div>
        </div>
    </div>
</header>
<style>
html,
body {
    margin: 0 !important;
}

/* =========================
   BODY / LAYOUT
========================= */
body {
    padding-top: 154px !important;
}

/* =========================
   NAVBAR FIXE
========================= */
.deen-navbar {
    display: block;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    margin-top: 0 !important;
    box-shadow: 0 4px 18px rgba(0, 0, 0, 0.06);
    z-index: 1040;
}

.deen-topbar {
    margin-top: 0 !important;
}

/* =========================
   MENU MOBILE
========================= */
.vs-menu-wrapper {
    top: 0 !important;
    margin-top: 0 !important;
    z-index: 1050;
}

.vs-menu-wrapper.open {
    opacity: 1;
    visibility: visible;
}

.vs-menu-wrapper.open .vs-menu-area {
    left: 0;
    opacity: 1;
    visibility: visible;
}

/* =========================
   MOBILE ACTIONS
========================= */
.deen-mobile-actions {
    display: none;
}

/* =========================
   WHATSAPP FLOAT
========================= */
.deen-whatsapp-float {
    position: fixed;
    left: 22px;
    bottom: 28px;
    width: 58px;
    height: 58px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background-color: #25d366;
    color: #fff;
    font-size: 31px;
    box-shadow: 0 12px 28px rgba(37, 211, 102, 0.35);
    z-index: 99990;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

.deen-whatsapp-float:hover {
    color: #fff;
    transform: translateY(-3px) scale(1.03);
    box-shadow: 0 16px 34px rgba(37, 211, 102, 0.42);
}

/* =========================
   MODAL FIX (IMPORTANT)
========================= */
.modal {
    z-index: 20000 !important;
}

.modal-backdrop {
    z-index: 19990 !important;
}

/* ✅ FIX SCROLL MOBILE MODAL (TON PROBLÈME) */
@media (max-width: 576px) {

    /* IMPORTANT : on laisse le modal centré */
    #authModal .modal-dialog {
        margin: 1.5rem;
    }

    /* Le contenu reste limité en hauteur */
    #authModal .modal-content {
        max-height: calc(100vh - 3rem);
        overflow: hidden;
        border-radius: 16px;
        display: flex;
        flex-direction: column;
    }

    /* Zone scroll uniquement ici */
    #authModal .modal-body {
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
    }
}

/* =========================
   TAB AUTH
========================= */
#authTab .nav-link {
    color: #6c757d;
}
#authModal .modal-content {
    max-width: 95%;
    margin: auto;
}

#authTab .nav-link.active {
    background-color: var(--theme-color) !important;
    color: white !important;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

/* =========================
   FORM
========================= */
.modal-content {
    transition: all 0.3s ease-in-out;
}

.form-control:focus {
    background-color: #fff !important;
    border: 1px solid var(--theme-color) !important;
}

/* =========================
   RESPONSIVE TABLET
========================= */
@media (max-width: 991.98px) {

    body {
        padding-top: 100px !important;
    }

    .vs-menu-wrapper {
        position: fixed !important;
    }

    .deen-topbar {
        overflow-x: auto;
        overflow-y: hidden;
        white-space: nowrap;
        scrollbar-width: thin;
    }

    .deen-topbar .container,
    .deen-topbar .row {
        width: max-content;
        max-width: none;
        flex-wrap: nowrap;
    }

    .deen-topbar-info,
    .deen-topbar-actions {
        display: flex;
        align-items: center;
    }

    .deen-main-header {
        padding-top: 8px !important;
        padding-bottom: 8px !important;
    }

    .deen-header-logo {
        max-height: 52px !important;
    }

    .deen-action-btn {
        width: 36px !important;
        height: 36px !important;
        min-width: 36px;
        font-size: 14px;
    }

    .deen-action-btn .badge {
        font-size: 10px;
        min-width: 17px;
        height: 17px;
        padding: 3px 5px;
    }

    .vs-menu-area {
        max-height: 100vh;
        overflow-y: auto;
        -webkit-overflow-scrolling: touch;
    }

    .mobile-logo {
        position: sticky;
        top: 0;
        z-index: 2;
        background: #fff;
        padding: 10px 16px;
    }

    .vs-mobile-menu {
        max-height: calc(100vh - 95px);
        overflow-y: auto;
    }

    .deen-mobile-actions {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin: 18px 16px 8px;
        padding: 14px;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
        text-align: left;
    }
}

/* =========================
   SMALL MOBILE
========================= */
@media (max-width: 575.98px) {

    body {
        padding-top: 88px !important;
    }

    .deen-topbar {
        padding-top: 5px !important;
        padding-bottom: 5px !important;
    }

    .deen-topbar .small {
        font-size: 11px;
    }

    .deen-header-logo {
        max-height: 46px !important;
    }

    .deen-action-btn {
        width: 34px !important;
        height: 34px !important;
        min-width: 34px;
    }

    .deen-whatsapp-float {
        width: 48px;
        height: 48px;
        font-size: 26px;
    }
}
</style>

<!-- JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
 <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script> 
  <script src="assets/js/index.js"></script>

<script>
    {% if app.user %}
        window.USER_LOGGED_IN = true;
    {% else %}
        window.USER_LOGGED_IN = false;
    {% endif %}

    document.addEventListener('DOMContentLoaded', function () {

        {% if app.flashes('login_error') is not empty %}
            let authModal = new bootstrap.Modal(document.getElementById('authModal'));
            authModal.show();
        {% endif %}

    });
</script>
<script>
document.addEventListener('DOMContentLoaded', function () {

    {% if app.session.flashBag.has('login_error') %}

        let authModal = new bootstrap.Modal(
            document.getElementById('authModal'),
            {
                backdrop: 'static',
                keyboard: false
            }
        );

        authModal.show();

    {% endif %}

});
</script>
{{ include('components/modal_auth.html.twig') }}
</body>
</html>
